# Art Value — Supabase configuration
# Copy this file to ".env" and fill in your project's values.
# Both must be present to switch the app into Supabase (cloud + auth) mode.
# Vite bakes these into the bundle at BUILD time — rebuild after changing them.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

# ---- Gemini (AI Quote Diagnosis) ----
# Get a key at https://aistudio.google.com/apikey
# NOTE: this is baked into the frontend bundle — restrict the key / move to a
# serverless proxy before heavy production use. Without it, the feature runs in demo mode.
VITE_GEMINI_API_KEY=YOUR-GEMINI-API-KEY
# optional model override (default: gemini-2.0-flash)
VITE_GEMINI_MODEL=gemini-2.0-flash

# ---- Local LLM (the assistant "ג'יק" on your own GPU — free & unlimited) ----
# Install Ollama (https://ollama.com), then: ollama pull aya-expanse:8b
# When VITE_LOCAL_LLM_URL is set, ALL text AI runs locally instead of Gemini cloud.
VITE_LOCAL_LLM_URL=http://127.0.0.1:11434/v1
VITE_LOCAL_LLM_MODEL=aya-expanse:8b
# image model for the AI image studio (Nano Banana). default: gemini-2.5-flash-image
# NOTE: image generation requires billing enabled on the Google project (free tier = text only).
VITE_GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# ---- Local image generation (your own GPU — free, only electricity) ----
# Option A: AUTOMATIC1111 / Forge — run with: webui --api --cors-allow-origins=*
VITE_LOCAL_IMAGE_URL=http://127.0.0.1:7860
# Option B (recommended): ComfyUI — run with: --enable-cors-header * --port 8188
# Two quality presets: COMFYUI_MODEL = fast SDXL, COMFYUI_FLUX_MODEL = max-quality Flux.
VITE_COMFYUI_URL=http://127.0.0.1:8188
VITE_COMFYUI_MODEL=RealVisXL_V4.0.safetensors
VITE_COMFYUI_FLUX_MODEL=flux1-dev-fp8.safetensors
# image→video model (Stable Video Diffusion XT) — enables the "image → animation" tab
VITE_COMFYUI_SVD_MODEL=svd_xt_1_1.safetensors
# FLUX.1 Kontext UNet (in models/diffusion_models/) — instruction photo-editing that
# preserves people/faces. Reuses the Flux checkpoint's CLIP+VAE, so only the UNet is needed.
VITE_COMFYUI_KONTEXT_MODEL=flux1-dev-kontext_fp8_scaled.safetensors

# ---- Pollinations (image gen — requires an API key now) ----
# Get a free key at https://enter.pollinations.ai (sign in with GitHub → create key).
#   pk_...  publishable, frontend-safe, but rate-limited (~1 image / IP / hour)
#   sk_...  secret, no rate limit — fine for an INTERNAL/local tool, but it is baked
#           into the bundle, so never ship it on a public website.
VITE_POLLINATIONS_TOKEN=
# optional image model (default: flux). others: turbo, gptimage
VITE_POLLINATIONS_MODEL=flux
